---
const { trip, title } = Astro.props;
import "../styles/planner.css";
// Optional: the research back end (worker/) base URL. Set PUBLIC_API_BASE at
// build time to light up the "re-plan these dates" panel; unset, the planners
// stay fully static with no network at view time.
const apiBase = import.meta.env.PUBLIC_API_BASE || "";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link
      rel="manifest"
      href={import.meta.env.BASE_URL.replace(/\/?$/, "/") + "manifest.webmanifest"}
    />
    <meta
      name="theme-color"
      content="#eeebe3"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#171813"
      media="(prefers-color-scheme: dark)"
    />
    <script is:inline>
  // Apply a saved theme before paint to avoid a flash of the wrong mode.
  try {
    var _saved = localStorage.getItem("theme");
    if (_saved) document.documentElement.setAttribute("data-theme", _saved);
  } catch (e) {}
    </script>
    <script is:inline>
  // Installable + offline (PWA). Relative path -> resolves under the
  // /trip-planner base; scope defaults to the same directory.
  if ("serviceWorker" in navigator) {
    addEventListener("load", function () {
      navigator.serviceWorker.register("service-worker.js").catch(function () {});
    });
  }
    </script>
  </head>
  <body>
<header class="site-nav no-print" id="siteNav">
  <a class="site-wordmark" href="index.html"
    ><span class="star">✦</span> <span class="wordmark-label">Trip Planner</span></a
  >
  <button
    class="nav-toggle"
    id="navToggle"
    type="button"
    aria-label="Menu"
    aria-expanded="false"
    aria-controls="navCollapse"
  >
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      aria-hidden="true"
    >
      <path d="M3 6h18M3 12h18M3 18h18"></path>
    </svg>
  </button>
  <!-- On mobile this wrapper is the hamburger dropdown; on desktop it uses
       display:contents so the tabs/theme/change-trip lay out inline in the
       nav flex exactly as before. -->
  <div class="nav-collapse" id="navCollapse">
    <nav class="tabs" aria-label="Planner sections">
      <button
        class="tab active"
        data-tab="plan"
        type="button"
        aria-pressed="true"
      >
        Plan &amp; Budget
      </button>
      <button class="tab" data-tab="itin" type="button" aria-pressed="false">
        Itinerary
      </button>
    </nav>
    <button
      class="theme-toggle"
      id="themeToggle"
      type="button"
      aria-label="Toggle light or dark mode"
      title="Toggle light / dark"
    >
      <span class="tt-icon" aria-hidden="true"></span>
      <span class="tt-label"></span>
    </button>
    <div class="site-changewrap">
      <button
        class="site-change"
        id="changeTripBtn"
        type="button"
        aria-haspopup="true"
        aria-expanded="false"
      >
        <span class="ct-icon" aria-hidden="true">↺</span>
        <span class="change-label">Change trip</span>
        <span class="ct-caret" aria-hidden="true">▾</span>
      </button>
      <div
        class="trip-menu"
        id="tripMenu"
        role="menu"
        aria-label="Change trip"
        hidden
      ></div>
    </div>
  </div>
</header>
<div class="nav-backdrop no-print" id="navBackdrop" hidden></div>

<div class="wrap pane" id="planPane">
  <header class="masthead">
    <div class="eyebrow" id="planEyebrow">
      Nov 14 → Nov 22, 2026 ·
      <span class="traveler-count-lbl">2</span> travelers · self-booked (DIY)
    </div>
    <h1 id="planTitle">Japan Trip Cost Ledger</h1>
    <p class="sub" id="planSub">
      Pick a hotel tier per stop and a transport mode per leg. Every figure is a
      live-researched market rate for these exact dates — not an estimate. The
      total updates as you go.
    </p>
  </header>

  <div id="liveMount" class="no-print"></div>

  <div id="scenarioMount" class="no-print"></div>

  <div class="route">
    <!-- FLIGHTS — getting there -->
    <div class="stop flights-section">
      <div class="stop-marker"></div>
      <div class="stop-head">
        <h2 id="flightsTitle">Getting there — International flights</h2>
        <span class="nights" id="flightsCount">round trip</span>
      </div>
      <p class="flights-intro" id="flightsIntro">
        Two travelers converging in Tokyo from different origins. Pick a routing
        for each — fares fold into the grand total. This block is data-driven:
        edit the <code>FLIGHTS</code> object to add travelers, routings, or
        fares.
      </p>
      <div class="origin-quiz" id="originQuiz">
        <div class="quiz-row">
          <label for="travelerCount">How many travelers?</label>
          <input
            type="number"
            id="travelerCount"
            min="1"
            max="8"
            value="2"
            inputmode="numeric"
          />
        </div>
        <div class="quiz-row">
          <span class="quiz-q">How are you getting there?</span>
          <div class="quiz-toggle" id="arriveModeSeg">
            <label
              ><input type="radio" name="arriveMode" value="fly" checked /><span
                >Flying</span
              ></label
            >
            <label
              ><input type="radio" name="arriveMode" value="drive" /><span
                >Driving</span
              ></label
            >
          </div>
        </div>
        <div class="quiz-row" id="flyOnly">
          <span class="quiz-q">Is everyone flying from the same airport?</span>
          <div class="quiz-toggle" id="sameAirportSeg">
            <label
              ><input type="radio" name="sameAirport" value="no" checked /><span
                >No — different airports</span
              ></label
            >
            <label
              ><input type="radio" name="sameAirport" value="yes" /><span
                >Yes — same airport</span
              ></label
            >
          </div>
        </div>
      </div>
      <div id="originsContainer" class="flight-journey"></div>
      <div id="driveBlock" class="flight-journey" style="display: none">
        <p class="flights-caveat">
          Driving to the start — no airfare in the total. Enter the one-way
          distance and we estimate premium fuel for the round trip (+15% for
          real-world detours, about $5/gal). If the drive takes more than a day
          each way, add overnight stops and we fold in en-route lodging. Leave
          miles at 0 to skip it.
        </p>
        <div class="quiz-row">
          <label class="origin-pax"
            >One-way distance (miles)
            <input
              type="number"
              id="driveMiles"
              min="0"
              value="0"
              inputmode="numeric"
          /></label>
          <label class="origin-pax"
            >Your vehicle MPG
            <input
              type="number"
              id="driveMpg"
              min="1"
              value="25"
              inputmode="numeric"
          /></label>
          <span class="origin-pax"
            >Est. fuel: <strong id="driveCostOut">$0</strong></span
          >
        </div>
        <div class="quiz-row">
          <label class="origin-pax"
            >Days for the drive (each way)
            <input
              type="number"
              id="driveDays"
              min="1"
              value="1"
              inputmode="numeric"
          /></label>
          <label class="origin-pax"
            >Overnight stop ($/night)
            <input
              type="number"
              id="driveStopRate"
              min="0"
              value="120"
              inputmode="numeric"
          /></label>
          <span class="origin-pax"
            >Overnight stops: <strong id="driveStopsOut">0</strong></span
          >
        </div>
      </div>
      <p class="flights-caveat" id="flightsCaveat"></p>
    </div>

    <div class="trip-settings">
      <div class="setting" id="rentalSetting">
        <label>Renting a car?</label>
        <div class="quiz-toggle" id="rentalSeg">
          <label
            ><input type="radio" name="renting" value="yes" checked /><span
              >Yes</span
            ></label
          >
          <label
            ><input type="radio" name="renting" value="no" /><span
              >No</span
            ></label
          >
        </div>
      </div>
      <div class="setting">
        <label for="minRating">Min. hotel rating</label>
        <input
          type="number"
          id="minRating"
          min="0"
          max="10"
          step="0.1"
          value="8.0"
          inputmode="decimal"
        />
        <span class="setting-hint">/ 10</span>
      </div>
    </div>

    <div class="extra-night">
      <div class="label-row">
        <span>Nights per stop</span>
        <span id="extraNightHint">7 nights total</span>
      </div>
      <div class="nightsteps" id="extraNightSeg"></div>
    </div>

    <!-- The whole leg + stop sequence is generated from TRIP by
         renderRouteBody(): arrival leg → stops with inter-city legs →
         optional-city blocks → departure leg. -->
    <div id="routeBody"></div>
  </div>

  <aside class="summary" id="summaryPanel">
    <!-- On mobile this bar is the tap target that expands the drawer below;
         on desktop it's just the panel header and the drawer is always open
         (see the collapse mechanics in planner.css + initSummaryCollapse()). -->
    <button
      class="sum-bar"
      id="summaryToggle"
      type="button"
      aria-expanded="false"
      aria-controls="sumDrawer"
    >
      <span class="sum-figure">
        <span class="eyebrow">
          Grand total<span class="gt-pax">
            · <span class="traveler-count-lbl">2</span> travelers</span
          >
        </span>
        <span
          class="grand-total"
          id="grandTotal"
          aria-live="polite"
          aria-atomic="true"
          >$0</span
        >
      </span>
      <span class="delta" id="deltaLine"></span>
      <span class="chev" aria-hidden="true">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M18 15l-6-6-6 6"></path>
        </svg>
      </span>
    </button>

    <div class="sum-drawer" id="sumDrawer">
      <div class="breakdown" id="breakdown"></div>

      <div class="reference-note" id="referenceNote"></div>

      <div class="btn-row">
        <button class="generate-btn" id="generateBtn" type="button">
          Shareable text
        </button>
        <button
          class="generate-btn secondary"
          id="downloadXlsxBtn"
          type="button"
        >
          Download Excel
        </button>
      </div>
    </div>
  </aside>

  <div class="modal-overlay" id="modalOverlay">
    <div
      class="modal-box"
      role="dialog"
      aria-modal="true"
      aria-labelledby="modalTitle"
    >
      <div class="modal-head">
        <h2 id="modalTitle">Shareable itinerary</h2>
        <button class="modal-close" id="modalClose" type="button">
          close ✕
        </button>
      </div>
      <div class="modal-note" id="modalNote" style="display: none"></div>
      <textarea
        id="shareOutput"
        readonly
        spellcheck="false"
        aria-labelledby="modalTitle"
      ></textarea>
      <div class="modal-actions">
        <button id="copyBtn" type="button">Copy to clipboard</button>
        <button class="secondary" id="modalCloseBottom" type="button">
          Close
        </button>
      </div>
    </div>
  </div>

  <footer class="notes">
    <h3>Methodology</h3>
    <ul id="finePrintList">
      <li>
        All hotel rates are live, date-locked quotes for the actual stay dates
        (Nov 2026), pulled directly from booking platforms — not seasonal floor
        rates.
      </li>
      <li>
        Every alternative hotel holds a private double/twin room, ≥8.0 guest
        rating, and the same neighborhood (or one stop away) as the
        currently-quoted property.
      </li>
      <li>
        Transport fares are current published prices (JR, Odakyu, Nankai,
        Kintetsu) plus representative private-transfer quotes from real booking
        platforms (Klook, Viator, Welcome Pickups).
      </li>
      <li>
        International flights ARE now included in the grand total, as researched
        representative Nov-2026 round-trip fares (per the Flights section) —
        these are estimates, not the date-locked quotes used for hotels. The
        Kensington reference comparison stays ground-only, since that quote also
        excluded airfare.
      </li>
      <li>
        Excluded from every total: Japan's ~10% accommodation tax (varies by
        city/hotel), meals outside included breakfasts, and activity/entrance
        fees.
      </li>
      <li>
        Kyoto→Osaka and Osaka→Kansai legs show public-transit cost only —
        private car quotes for those specific legs weren't part of this research
        pass.
      </li>
    </ul>
  </footer>
</div>

<div class="itinwrap pane" id="itinPane" style="display: none">
  <header class="masthead">
    <div class="eyebrow" id="itinEyebrow">
      Nov 14 → Nov 22, 2026 ·
      <span class="traveler-count-lbl">2</span> travelers · self-booked
    </div>
    <h1 id="itinTitle">Your itinerary</h1>
    <p class="sub" id="itinDek">
      The day-by-day, built from your choices on the Plan tab — the hotels you
      picked, the transport modes, your flights. Set the pace, choose whether to
      show prices, then send it.
    </p>
  </header>

  <div class="itin-controls no-print">
    <span
      ><span class="lbl">Pace</span
      ><span class="toggle" id="itinPaceSeg" style="vertical-align: middle">
        <input
          type="radio"
          name="itinpace"
          id="ip-relaxed"
          value="relaxed"
          checked
        /><label for="ip-relaxed">Relaxed</label>
        <input
          type="radio"
          name="itinpace"
          id="ip-classic"
          value="classic"
        /><label for="ip-classic">Classic</label>
        <input
          type="radio"
          name="itinpace"
          id="ip-custom"
          value="custom"
        /><label for="ip-custom">Custom</label>
      </span></span
    >
    <label class="price-toggle"
      ><input type="checkbox" id="showPrices" /> Show prices</label
    >
    <div class="spacer"></div>
    <button
      class="generate-btn"
      id="itinPdfBtn"
      type="button"
      style="flex: 0 0 auto"
    >
      Create PDF to send
    </button>
    <button
      class="generate-btn secondary"
      id="itinCopyBtn"
      type="button"
      style="flex: 0 0 auto"
    >
      Copy as text
    </button>
    <button
      class="generate-btn secondary"
      id="itinXlsxBtn"
      type="button"
      style="flex: 0 0 auto"
    >
      Download Excel
    </button>
    <button
      class="generate-btn secondary"
      id="itinIcsBtn"
      type="button"
      style="flex: 0 0 auto"
    >
      Calendar (.ics)
    </button>
    <span
      class="no-print"
      id="pdfHint"
      style="
        display: none;
        flex-basis: 100%;
        font-size: 0.78rem;
        color: var(--shu);
        text-align: right;
        line-height: 1.4;
      "
    ></span>
  </div>
  <div
    class="itin-summary no-print"
    id="itinSummary"
    style="margin: -1rem 0 1.5rem; text-align: right"
  ></div>

  <!-- Progressive enhancement: the engine fills this only when PUBLIC_API_BASE
       is set (see apiBase above). Empty/invisible otherwise. -->
  <div id="replanMount" class="no-print"></div>

  <div id="itinRail"></div>
  <div class="itin-total" id="itinTotal" style="display: none"></div>

  <footer class="notes" style="margin-top: 2rem">
    <h3>The fine print</h3>
    <ul>
      <li>
        Hotels, transport modes, and flights shown here are exactly what's
        selected on the Plan tab — change them there and this rebuilds.
      </li>
      <li>
        "+ fuller" items are optional experience upgrades; toggle them per day,
        or with the pace switch (Classic turns them all on).
      </li>
      <li>Flights and a few dinner reservations are still to be locked in.</li>
    </ul>
  </footer>
</div>
    <script is:inline define:vars={{ TRIP: trip, API_BASE: apiBase }}>
      // hand the trip data to the engine module (loads after parse)
      window.TRIP = TRIP;
      // optional research back-end base URL (empty = feature off)
      window.__API_BASE = API_BASE;
    </script>
    <script>
      import "../scripts/engine.js";
    </script>
  </body>
</html>
