---
// Landing page — pick a destination. Ported from index.html.
// URLs stay relative (japan-trip-planner.html, etc.) so links resolve
// under the /trip-planner base on GitHub Pages exactly as before.
//
// The trip cards are generated from each data module's meta.hub — adding a
// trip = data module + 3-line page; the card appears here automatically.
const modules = import.meta.glob("../data/*.js", { eager: true });
const trips = Object.entries(modules)
  .map(([path, mod]) => {
    const slug = path.split("/").pop().replace(/\.js$/, "");
    const hub = (mod.default && mod.default.meta && mod.default.meta.hub) || null;
    return hub ? { slug, ...hub } : null;
  })
  .filter(Boolean)
  .sort((a, b) => (a.order || 99) - (b.order || 99));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Trip Planner — pick a destination</title>
    <style is:global>
      @font-face {
        font-family: "Ledger Serif";
        src:
          local("Iowan Old Style"), local("Palatino Linotype"),
          local("Palatino");
      }
      :root {
        --paper: #eeebe3;
        --paper-raised: #f7f5ef;
        --ink: #201f1a;
        --ink-soft: #5a5648;
        --indigo: #26456b;
        --indigo-deep: #16293f;
        --line: #d5d0c1;
        --line-strong: #b7b09a;
        --focus: #26456b;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --paper: #171813;
          --paper-raised: #201f19;
          --ink: #ece8dc;
          --ink-soft: #b0aa98;
          --indigo: #86a7cd;
          --indigo-deep: #b9cfe8;
          --line: #38362c;
          --line-strong: #4c4939;
          --focus: #b9cfe8;
        }
      }
      /* manual toggle wins over the OS preference (same as the planners) */
      :root[data-theme="dark"] {
        --paper: #171813;
        --paper-raised: #201f19;
        --ink: #ece8dc;
        --ink-soft: #b0aa98;
        --indigo: #86a7cd;
        --indigo-deep: #b9cfe8;
        --line: #38362c;
        --line-strong: #4c4939;
        --focus: #b9cfe8;
      }
      :root[data-theme="light"] {
        --paper: #eeebe3;
        --paper-raised: #f7f5ef;
        --ink: #201f1a;
        --ink-soft: #5a5648;
        --indigo: #26456b;
        --indigo-deep: #16293f;
        --line: #d5d0c1;
        --line-strong: #b7b09a;
        --focus: #26456b;
      }
      .theme-toggle {
        position: absolute;
        top: 1.4rem;
        right: clamp(1rem, 4vw, 2rem);
        width: 2.2rem;
        height: 2.2rem;
        border-radius: 999px;
        border: 1px solid var(--line-strong);
        background: var(--paper-raised);
        color: var(--ink-soft);
        font-size: 0.95rem;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      .theme-toggle:hover {
        border-color: var(--indigo);
        color: var(--ink);
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        min-height: 100vh;
        background: var(--paper);
        color: var(--ink);
        font-family:
          ui-sans-serif,
          -apple-system,
          "Segoe UI",
          Roboto,
          Helvetica,
          Arial,
          sans-serif;
        line-height: 1.5;
        display: flex;
        justify-content: center;
        padding: 2rem 1.25rem 4rem;
      }
      .wrap {
        width: 100%;
        max-width: 720px;
      }
      .eyebrow {
        font-family: ui-monospace, "SF Mono", Consolas, monospace;
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--ink-soft);
        margin: 0 0 0.6rem;
      }
      h1 {
        font-family: "Ledger Serif", Georgia, serif;
        font-weight: 600;
        font-size: clamp(2rem, 6vw, 2.9rem);
        line-height: 1.1;
        margin: 0 0 0.7rem;
        text-wrap: balance;
      }
      .lede {
        font-size: 1.05rem;
        color: var(--ink-soft);
        max-width: 52ch;
        margin: 0 0 2.2rem;
      }
      .calendar-link {
        margin: 0 0 1.6rem;
      }
      .calendar-link a {
        font-family: ui-monospace, "SF Mono", Consolas, monospace;
        font-size: 0.8rem;
        letter-spacing: 0.04em;
        font-weight: 600;
        color: var(--indigo);
        text-decoration: none;
      }
      .calendar-link a:hover {
        text-decoration: underline;
      }
      .trips {
        display: grid;
        gap: 1rem;
      }
      .trip {
        display: block;
        text-decoration: none;
        color: inherit;
        background: var(--paper-raised);
        border: 1px solid var(--line);
        border-left: 4px solid var(--indigo);
        border-radius: 6px;
        padding: 1.3rem 1.4rem;
        transition:
          transform 0.12s ease,
          border-color 0.12s ease,
          box-shadow 0.12s ease;
      }
      .trip:hover,
      .trip:focus-visible {
        transform: translateY(-2px);
        border-left-color: var(--indigo-deep);
        box-shadow: 0 6px 22px rgba(0, 0, 0, 0.14);
        outline: none;
      }
      .trip:focus-visible {
        outline: 2px solid var(--focus);
        outline-offset: 2px;
      }
      .trip-title {
        font-family: "Ledger Serif", Georgia, serif;
        font-size: 1.5rem;
        margin: 0 0 0.25rem;
        display: flex;
        align-items: center;
        gap: 0.55rem;
      }
      .trip-meta {
        font-family: ui-monospace, "SF Mono", Consolas, monospace;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--ink-soft);
        margin: 0 0 0.6rem;
      }
      .trip-desc {
        margin: 0;
        color: var(--ink-soft);
        font-size: 0.95rem;
      }
      .go {
        margin-top: 0.9rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--indigo);
      }
      .foot {
        margin-top: 2.4rem;
        font-size: 0.8rem;
        color: var(--ink-soft);
      }
    </style>
  </head>
  <body>
    <script is:inline>
      // Apply a saved theme before paint (shared "theme" key with the planners).
      try {
        var _saved = localStorage.getItem("theme");
        if (_saved) document.documentElement.setAttribute("data-theme", _saved);
      } catch (e) {}
    </script>
    <button
      class="theme-toggle"
      id="themeToggle"
      type="button"
      aria-label="Toggle light or dark mode"
      title="Toggle light / dark"></button>
    <main class="wrap">
      <p class="eyebrow">
        <span style="color: var(--indigo)">✦</span> Trip Planner
      </p>
      <h1>Pick a destination, get a plan.</h1>
      <p class="lede">
        Each planner lets you choose your own flights, lodging tier, and pace —
        the budget and a day-by-day itinerary rebuild from your picks, ready to
        print or export. Everything is a researched planning estimate; verify
        live before booking.
      </p>

      <p class="calendar-link">
        <a href="calendar.html">🗓 See the whole year on one calendar →</a>
      </p>

      <div class="trips">
        {
          trips.map((t) => (
            <a class="trip" href={t.slug + '-trip-planner.html'}>
              <h2 class="trip-title">{t.emoji} {t.title}</h2>
              <p class="trip-meta">{t.meta}</p>
              <p class="trip-desc">{t.blurb}</p>
              <div class="go">Open the {t.go} planner →</div>
            </a>
          ))
        }
      </div>

      <p class="foot">
        Self-contained pages — no accounts, no tracking. Your selections stay in
        your browser.
      </p>
    </main>
    <script is:inline>
      // Theme toggle — same behavior + storage key as the planners.
      (function () {
        const root = document.documentElement;
        const btn = document.getElementById("themeToggle");
        const mq = window.matchMedia("(prefers-color-scheme: dark)");
        const isDark = () => {
          const a = root.getAttribute("data-theme");
          return a ? a === "dark" : mq.matches;
        };
        const paint = () => (btn.textContent = isDark() ? "☀" : "☾");
        btn.addEventListener("click", () => {
          const next = isDark() ? "light" : "dark";
          root.setAttribute("data-theme", next);
          try {
            localStorage.setItem("theme", next);
          } catch (e) {}
          paint();
        });
        mq.addEventListener("change", () => {
          if (!root.getAttribute("data-theme")) paint();
        });
        paint();
      })();
    </script>
  </body>
</html>
