---
// Landing page — pick a destination. Ported from index.html.
// URLs stay relative (japan-trip-planner.html, etc.) so links resolve
// under the /trip-planner base on GitHub Pages exactly as before.
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Trip Planner — pick a destination</title>
    <style is:global>
      @font-face {
        font-family: "Ledger Serif";
        src:
          local("Iowan Old Style"), local("Palatino Linotype"),
          local("Palatino");
      }
      :root {
        --paper: #eeebe3;
        --paper-raised: #f7f5ef;
        --ink: #201f1a;
        --ink-soft: #5a5648;
        --indigo: #26456b;
        --indigo-deep: #16293f;
        --line: #d5d0c1;
        --line-strong: #b7b09a;
        --focus: #26456b;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --paper: #171813;
          --paper-raised: #201f19;
          --ink: #ece8dc;
          --ink-soft: #b0aa98;
          --indigo: #86a7cd;
          --indigo-deep: #b9cfe8;
          --line: #38362c;
          --line-strong: #4c4939;
          --focus: #b9cfe8;
        }
      }
      /* manual toggle wins over the OS preference (same as the planners) */
      :root[data-theme="dark"] {
        --paper: #171813;
        --paper-raised: #201f19;
        --ink: #ece8dc;
        --ink-soft: #b0aa98;
        --indigo: #86a7cd;
        --indigo-deep: #b9cfe8;
        --line: #38362c;
        --line-strong: #4c4939;
        --focus: #b9cfe8;
      }
      :root[data-theme="light"] {
        --paper: #eeebe3;
        --paper-raised: #f7f5ef;
        --ink: #201f1a;
        --ink-soft: #5a5648;
        --indigo: #26456b;
        --indigo-deep: #16293f;
        --line: #d5d0c1;
        --line-strong: #b7b09a;
        --focus: #26456b;
      }
      .theme-toggle {
        position: absolute;
        top: 1.4rem;
        right: clamp(1rem, 4vw, 2rem);
        width: 2.2rem;
        height: 2.2rem;
        border-radius: 999px;
        border: 1px solid var(--line-strong);
        background: var(--paper-raised);
        color: var(--ink-soft);
        font-size: 0.95rem;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      .theme-toggle:hover {
        border-color: var(--indigo);
        color: var(--ink);
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        min-height: 100vh;
        background: var(--paper);
        color: var(--ink);
        font-family:
          ui-sans-serif,
          -apple-system,
          "Segoe UI",
          Roboto,
          Helvetica,
          Arial,
          sans-serif;
        line-height: 1.5;
        display: flex;
        justify-content: center;
        padding: 2rem 1.25rem 4rem;
      }
      .wrap {
        width: 100%;
        max-width: 720px;
      }
      .eyebrow {
        font-family: ui-monospace, "SF Mono", Consolas, monospace;
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--ink-soft);
        margin: 0 0 0.6rem;
      }
      h1 {
        font-family: "Ledger Serif", Georgia, serif;
        font-weight: 600;
        font-size: clamp(2rem, 6vw, 2.9rem);
        line-height: 1.1;
        margin: 0 0 0.7rem;
        text-wrap: balance;
      }
      .lede {
        font-size: 1.05rem;
        color: var(--ink-soft);
        max-width: 52ch;
        margin: 0 0 2.2rem;
      }
      .calendar-link {
        margin: 0 0 1.6rem;
      }
      .calendar-link a {
        font-family: ui-monospace, "SF Mono", Consolas, monospace;
        font-size: 0.8rem;
        letter-spacing: 0.04em;
        font-weight: 600;
        color: var(--indigo);
        text-decoration: none;
      }
      .calendar-link a:hover {
        text-decoration: underline;
      }
      .trips {
        display: grid;
        gap: 1rem;
      }
      .trip {
        display: block;
        text-decoration: none;
        color: inherit;
        background: var(--paper-raised);
        border: 1px solid var(--line);
        border-left: 4px solid var(--indigo);
        border-radius: 6px;
        padding: 1.3rem 1.4rem;
        transition:
          transform 0.12s ease,
          border-color 0.12s ease,
          box-shadow 0.12s ease;
      }
      .trip:hover,
      .trip:focus-visible {
        transform: translateY(-2px);
        border-left-color: var(--indigo-deep);
        box-shadow: 0 6px 22px rgba(0, 0, 0, 0.14);
        outline: none;
      }
      .trip:focus-visible {
        outline: 2px solid var(--focus);
        outline-offset: 2px;
      }
      .trip-title {
        font-family: "Ledger Serif", Georgia, serif;
        font-size: 1.5rem;
        margin: 0 0 0.25rem;
        display: flex;
        align-items: center;
        gap: 0.55rem;
      }
      .trip-meta {
        font-family: ui-monospace, "SF Mono", Consolas, monospace;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--ink-soft);
        margin: 0 0 0.6rem;
      }
      .trip-desc {
        margin: 0;
        color: var(--ink-soft);
        font-size: 0.95rem;
      }
      .go {
        margin-top: 0.9rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--indigo);
      }
      .foot {
        margin-top: 2.4rem;
        font-size: 0.8rem;
        color: var(--ink-soft);
      }
    </style>
  </head>
  <body>
    <script is:inline>
      // Apply a saved theme before paint (shared "theme" key with the planners).
      try {
        var _saved = localStorage.getItem("theme");
        if (_saved) document.documentElement.setAttribute("data-theme", _saved);
      } catch (e) {}
    </script>
    <button
      class="theme-toggle"
      id="themeToggle"
      type="button"
      aria-label="Toggle light or dark mode"
      title="Toggle light / dark"></button>
    <main class="wrap">
      <p class="eyebrow">
        <span style="color: var(--indigo)">✦</span> Trip Planner
      </p>
      <h1>Pick a destination, get a plan.</h1>
      <p class="lede">
        Each planner lets you choose your own flights, lodging tier, and pace —
        the budget and a day-by-day itinerary rebuild from your picks, ready to
        print or export. Everything is a researched planning estimate; verify
        live before booking.
      </p>

      <p class="calendar-link">
        <a href="calendar.html">🗓 See the whole year on one calendar →</a>
      </p>

      <div class="trips">
        <a class="trip" href="japan-trip-planner.html">
          <h2 class="trip-title">🗼 Japan</h2>
          <p class="trip-meta">Tokyo · Hakone · Kyoto · optional Osaka</p>
          <p class="trip-desc">
            Nine days by train through Tokyo, a Hakone onsen night, and old
            Kyoto — flights from two origins, ryokan-to-hotel lodging tiers, and
            a flexible ninth night.
          </p>
          <div class="go">Open the Japan planner →</div>
        </a>

        <a class="trip" href="yellowstone-trip-planner.html">
          <h2 class="trip-title">🏔️ Yellowstone &amp; Grand Teton</h2>
          <p class="trip-meta">Jackson · Old Faithful · Canyon · Mammoth</p>
          <p class="trip-desc">
            A driving loop through the Tetons and the Yellowstone grand loop —
            open-jaw flights, park-lodge or cabin tiers, and a rental SUV with
            fuel and park pass folded into the total.
          </p>
          <div class="go">Open the Yellowstone planner →</div>
        </a>

        <a class="trip" href="sw-trip-planner.html">
          <h2 class="trip-title">🏜️ Southwest Parks</h2>
          <p class="trip-meta">Las Vegas · Zion · Bryce · Grand Canyon</p>
          <p class="trip-desc">
            A red-rock driving loop out of Las Vegas through Zion, Bryce, and
            the Grand Canyon's South Rim — rental SUV, hiking-tier lodges, and
            every park entry folded in.
          </p>
          <div class="go">Open the Southwest planner →</div>
        </a>

        <a class="trip" href="italy-trip-planner.html">
          <h2 class="trip-title">🏛️ Italy by Rail</h2>
          <p class="trip-meta">Rome · Florence · Venice</p>
          <p class="trip-desc">
            The classic triangle by high-speed Frecciarossa train — open-jaw
            into Rome and out of Venice, city hotels from pensione to palazzo,
            Colosseum to canals.
          </p>
          <div class="go">Open the Italy planner →</div>
        </a>

        <a class="trip" href="hawaii-trip-planner.html">
          <h2 class="trip-title">🌺 Hawaii — O‘ahu &amp; Maui</h2>
          <p class="trip-meta">Waikiki · North Shore · Road to Hāna</p>
          <p class="trip-desc">
            Two islands with an inter-island hop — Waikiki and Pearl Harbor,
            then Maui's beaches and the Road to Hāna. Condo-to-resort tiers and
            a rental car on each island.
          </p>
          <div class="go">Open the Hawaii planner →</div>
        </a>

        <a class="trip" href="thailand-trip-planner.html">
          <h2 class="trip-title">🛕 Thailand</h2>
          <p class="trip-meta">Bangkok · Chiang Mai · Phuket</p>
          <p class="trip-desc">
            Temples, night markets, and southern beaches, linked by cheap
            domestic flights — hostel-chic to beach-resort tiers, street food
            the whole way down.
          </p>
          <div class="go">Open the Thailand planner →</div>
        </a>

        <a class="trip" href="redwoods-trip-planner.html">
          <h2 class="trip-title">🌲 California Redwoods</h2>
          <p class="trip-meta">Mendocino · Avenue of the Giants · Crescent City</p>
          <p class="trip-desc">
            A coastal loop out of San Francisco under the tallest trees on
            Earth — foggy coves, the Avenue of the Giants, Fern Canyon, and
            Roosevelt elk, with a rental SUV and park fees folded in.
          </p>
          <div class="go">Open the Redwoods planner →</div>
        </a>

        <a class="trip" href="zion-trip-planner.html">
          <h2 class="trip-title">🧗 Zion Deep-Dive</h2>
          <p class="trip-meta">Springdale · The Narrows · Angels Landing · Bryce</p>
          <p class="trip-desc">
            Four full days based in Springdale for the big Zion days — Angels
            Landing, the Narrows, Kolob Canyons — plus a night among Bryce's
            hoodoos on the way back to Vegas.
          </p>
          <div class="go">Open the Zion planner →</div>
        </a>

        <a class="trip" href="germany-trip-planner.html">
          <h2 class="trip-title">🎄 Christmas in Germany</h2>
          <p class="trip-meta">Nuremberg · Rothenburg · Munich</p>
          <p class="trip-desc">
            Christmas markets by rail — the Christkindlesmarkt, Rothenburg's
            walled old town at dusk, and Marienplatz under the lights, with
            glühwein at every stop.
          </p>
          <div class="go">Open the Germany planner →</div>
        </a>

        <a class="trip" href="seoul-trip-planner.html">
          <h2 class="trip-title">🏯 Seoul &amp; Busan</h2>
          <p class="trip-meta">Seoul · DMZ · KTX · Busan</p>
          <p class="trip-desc">
            Joseon palaces and night markets in Seoul, a day at the DMZ, then
            the KTX bullet train south to Busan's beaches, cliffside temples,
            and seafood markets — open-jaw, no rental car.
          </p>
          <div class="go">Open the Seoul planner →</div>
        </a>

        <a class="trip" href="philippines-trip-planner.html">
          <h2 class="trip-title">🏝️ Philippines</h2>
          <p class="trip-meta">Coron · Siargao · a week in Malita</p>
          <p class="trip-desc">
            Limestone lagoons and WWII wrecks in Coron, then a hop to Siargao
            for the surf and the lagoons, and a slow week in Malita with family
            near Davao — in through Manila, home open-jaw from Davao.
          </p>
          <div class="go">Open the Philippines planner →</div>
        </a>
      </div>

      <p class="foot">
        Self-contained pages — no accounts, no tracking. Your selections stay in
        your browser.
      </p>
    </main>
    <script is:inline>
      // Theme toggle — same behavior + storage key as the planners.
      (function () {
        const root = document.documentElement;
        const btn = document.getElementById("themeToggle");
        const mq = window.matchMedia("(prefers-color-scheme: dark)");
        const isDark = () => {
          const a = root.getAttribute("data-theme");
          return a ? a === "dark" : mq.matches;
        };
        const paint = () => (btn.textContent = isDark() ? "☀" : "☾");
        btn.addEventListener("click", () => {
          const next = isDark() ? "light" : "dark";
          root.setAttribute("data-theme", next);
          try {
            localStorage.setItem("theme", next);
          } catch (e) {}
          paint();
        });
        mq.addEventListener("change", () => {
          if (!root.getAttribute("data-theme")) paint();
        });
        paint();
      })();
    </script>
  </body>
</html>
